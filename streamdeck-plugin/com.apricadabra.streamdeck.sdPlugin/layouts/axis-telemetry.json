{
    "$schema": "https://schemas.elgato.com/streamdeck/plugins/layout.json",
    "id": "axis-telemetry",
    "items": [
        {
            "key": "label",
            "type": "text",
            "rect": [4, 4, 144, 28],
            "alignment": "left",
            "font": { "size": 18, "weight": 700 },
            "color": "#cccccc"
        },
        {
            "key": "value",
            "type": "text",
            "rect": [150, 4, 46, 28],
            "alignment": "right",
            "font": { "size": 20, "weight": 900 },
            "color": "#00F0FF"
        },
        {
            "key": "warning",
            "type": "text",
            "rect": [120, 34, 76, 20],
            "alignment": "right",
            "font": { "size": 14, "weight": 700 },
            "color": "#F3E600",
            "enabled": false
        },
        {
            "key": "bar",
            "type": "pixmap",
            "rect": [8, 76, 184, 18]
        }
    ]
}
