{
    "$schema": "https://schemas.elgato.com/streamdeck/plugins/layout.json",
    "id": "axis-telemetry",
    "items": [
        {
            "key": "title",
            "type": "text",
            "rect": [4, 4, 96, 28],
            "alignment": "left",
            "font": { "size": 16, "weight": 600 },
            "color": "#888888"
        },
        {
            "key": "value",
            "type": "text",
            "rect": [104, 4, 92, 28],
            "alignment": "right",
            "font": { "size": 24, "weight": 900 },
            "color": "#00F0FF"
        },
        {
            "key": "warning",
            "type": "text",
            "rect": [104, 34, 92, 20],
            "alignment": "right",
            "font": { "size": 16, "weight": 700 },
            "color": "#F3E600",
            "enabled": false
        },
        {
            "key": "bar",
            "type": "pixmap",
            "rect": [8, 76, 184, 18]
        }
    ]
}
