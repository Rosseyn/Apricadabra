{
  "SDKVersion": 2,
  "UUID": "com.apricadabra.streamdeck",
  "Name": "Stream Deck to vJoy",
  "Version": "1.0.0.0",
  "Description": "A vJoy feeder app that turns your Stream Deck dials and buttons into virtual joystick inputs for sim games. Requires vJoy: https://sourceforge.net/projects/vjoystick/",
  "Author": "apricadabra",
  "Category": "Stream Deck to vJoy",
  "CategoryIcon": "imgs/category-icon",
  "Icon": "imgs/plugin-icon",
  "CodePath": "bin/plugin.js",
  "Nodejs": {
    "Version": "20"
  },
  "OS": [{ "Platform": "windows", "MinimumVersion": "10" }],
  "Software": { "MinimumVersion": "6.9" },
  "Actions": [
    {
      "UUID": "com.apricadabra.streamdeck.dial",
      "Name": "vJoy Dial",
      "Tooltip": "Control a vJoy axis with the encoder dial. Supports Hold, Spring, and Detent modes.",
      "Icon": "imgs/dial-action",
      "Controllers": ["Encoder"],
      "States": [{ "Image": "imgs/dial-icon" }],
      "Encoder": {
        "layout": "$B1",
        "TriggerDescription": {
          "Rotate": "Adjust axis",
          "Push": "Fire button",
          "Touch": "Settings"
        }
      },
      "PropertyInspectorPath": "pi/dial.html"
    },
    {
      "UUID": "com.apricadabra.streamdeck.button",
      "Name": "vJoy Button",
      "Tooltip": "Fire a vJoy button press. Supports Momentary, Toggle, Pulse, Double, Rapid Fire, and Long/Short modes.",
      "Icon": "imgs/button-action",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/button-icon" }],
      "PropertyInspectorPath": "pi/button.html"
    },
    {
      "UUID": "com.apricadabra.streamdeck.reset",
      "Name": "vJoy Reset Axis",
      "Tooltip": "Reset a vJoy axis to a specific position (e.g. center at 50%).",
      "Icon": "imgs/reset-action",
      "Controllers": ["Keypad", "Encoder"],
      "States": [{ "Image": "imgs/reset-icon" }],
      "Encoder": {
        "layout": "$A0",
        "TriggerDescription": {
          "Push": "Reset axis"
        }
      },
      "PropertyInspectorPath": "pi/reset-axis.html"
    }
  ]
}
