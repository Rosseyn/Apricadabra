{
  "name": "com.apricadabra.streamdeck",
  "version": "0.2.0",
  "description": "Control vJoy virtual joystick axes and buttons from Stream Deck",
  "main": "bin/plugin.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/plugin.ts --bundle --platform=node --format=cjs --outfile=com.apricadabra.streamdeck.sdPlugin/bin/plugin.js",
    "watch": "npm run build -- --watch",
    "dev": "npm run watch",
    "deploy": "npm run build && cp -r com.apricadabra.streamdeck.sdPlugin /c/Users/unsab/AppData/Roaming/Elgato/StreamDeck/Plugins/"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  }
}
